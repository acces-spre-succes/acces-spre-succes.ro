# Copy this file to `.env` and fill in real values.
# `.env` is gitignored, `.env.example` is committed.
# Docker Compose automatically loads `.env` from this directory.

# --- Database ---
# Neon Postgres connection string (or any PostgreSQL URL).
# Format: jdbc:postgresql://HOST/DBNAME?sslmode=require&channel_binding=require
DB_URL=jdbc:postgresql://your-neon-host.neon.tech/your_db?sslmode=require&channel_binding=require
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Backend ---
SERVER_PORT=8080

# --- Stripe (test mode) ---
# Will be replaced with EuPlatesc later.
# Leave empty if you don't need payments to work locally.
STRIPE_SECRET_KEY=
