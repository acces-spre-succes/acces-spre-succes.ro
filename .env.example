# Copy this file to `.env` and fill in real values.
# `.env` is gitignored, `.env.example` is committed.
# Docker Compose automatically loads `.env` from this directory.

# --- Database ---
# Neon Postgres connection string (or any PostgreSQL URL).
# Format: jdbc:postgresql://HOST/DBNAME?sslmode=require&channel_binding=require
DB_URL=jdbc:postgresql://your-neon-host.neon.tech/your_db?sslmode=require&channel_binding=require
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Backend ---
SERVER_PORT=8080

# --- Auth ---
# Random secret used to sign JWTs. Must be at least 32 characters.
# Generate one with:
#   PowerShell:  $r=[System.Security.Cryptography.RandomNumberGenerator]::Create(); $b=New-Object byte[] 48; $r.GetBytes($b); [Convert]::ToBase64String($b)
#   Bash:        openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# Used only on the very first backend startup to seed the initial admin user.
# Once an admin exists, these are ignored.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme-then-rotate

# Comma-separated list of origins allowed to call /api/**.
# In production add: https://acces-spre-succes.ro,https://admin.acces-spre-succes.ro
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Stripe (test mode) ---
# Will be replaced with EuPlatesc.
# Leave empty if you don't need payments to work locally.
STRIPE_SECRET_KEY=
